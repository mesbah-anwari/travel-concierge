# Copy this file to .env and fill in your real keys.
# Never commit .env to source control.

# Google AI Studio key — get one free at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key-here

# Default model (cheap + fast; -lite has ~10x the free-tier daily quota of -flash)
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional: override default user locale for currency
DEFAULT_HOME_CURRENCY=USD
